# ============================================================
# HiveQuote environment configuration
# The app runs fully in MOCK MODE with zero keys configured.
# Paste real keys to activate each integration independently.
# ============================================================

# --- Supabase (database, auth, storage) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (all payments: wallets, ACH, subscriptions) ---
# Product naming rule: "Lead Generation Service", "Lead Generation Subscription",
# "Contractor Platform Setup", "Lead Wallet Funding" ONLY. Never "success fee",
# "referral fee", "performance fee", or "introduction fee".
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- GoHighLevel (CRM, SMS, pipelines) ---
GHL_API_KEY=
GHL_LOCATION_ID=

# --- Twilio (delivery receipts, call tracking fallback) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- SMS gate: keep false until A2P 10DLC registration is APPROVED ---
SMS_ACTIVE=false

# --- Admin dashboard access (simple gate until Supabase Auth roles are wired) ---
ADMIN_ACCESS_KEY=change-me

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://hivequote.com
